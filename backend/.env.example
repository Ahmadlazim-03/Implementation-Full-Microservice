# ===== Shared =====
APP_ENV=development
LOG_LEVEL=debug

# ===== Auth Service (PostgreSQL) =====
# Format: postgres://user:pass@host:port/dbname?sslmode=disable
POSTGRES_AUTH_DSN=postgres://auth_user:auth_pass@localhost:5433/kampusmap_auth?sslmode=disable

# ===== Places Service (MongoDB) =====
MONGO_PLACES_URI=mongodb://localhost:27018
MONGO_DB_PLACES=kampusmap_places

# ===== Review Service (MongoDB) =====
MONGO_REVIEW_URI=mongodb://localhost:27019
MONGO_DB_REVIEW=kampusmap_review

# ===== Redis (shared cache) =====
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT =====
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_HOURS=72

# ===== Service Ports =====
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
PLACES_SERVICE_PORT=8082
REVIEW_SERVICE_PORT=8083

# ===== Internal Service URLs (used by gateway, HTTP/JSON) =====
AUTH_SERVICE_URL=http://localhost:8081
PLACES_SERVICE_URL=http://localhost:8082
REVIEW_SERVICE_URL=http://localhost:8083

# ===== Internal gRPC (protobuf) — service-to-service =====
PLACES_GRPC_PORT=9082
AUTH_GRPC_PORT=9081
PLACES_GRPC_ADDR=localhost:9082
AUTH_GRPC_ADDR=localhost:9081
